# Supabase project (Settings -> API)
SUPABASE_URL=https://pkvdthwqvjpxhqorfpub.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Pause between a round's end and the next round's start, in milliseconds.
NEXT_ROUND_DELAY_MS=4000

# Extra grace period added after a round's time_limit_seconds before the
# server stops accepting answers, in milliseconds.
LATE_ANSWER_GRACE_MS=500

# Per-game lease length, in seconds. The worker re-heartbeats a game it owns
# every ENGINE_LEASE_SECONDS/2; if it dies, the lease lapses after this many
# seconds and another worker (or the same one after a restart) reclaims and
# resumes the game. Guards against orphaned games and double-driving.
ENGINE_LEASE_SECONDS=30

# Optional stable worker identity for lease ownership + the engine_heartbeats
# row. Defaults to hostname:pid:random, which is fine for a single Render
# worker; set it explicitly only if you want a fixed name across restarts.
# ENGINE_WORKER_ID=
