# Supabase project (Settings -> API)
SUPABASE_URL=https://pkvdthwqvjpxhqorfpub.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Pause between a round's end and the next round's start, in milliseconds.
NEXT_ROUND_DELAY_MS=4000

# Extra grace period added after a round's time_limit_seconds before the
# server stops accepting answers, in milliseconds.
LATE_ANSWER_GRACE_MS=500

# Per-game lease length, in seconds. While driving a game the worker re-heartbeats
# every ENGINE_LEASE_SECONDS/2; if the worker dies, its games become reclaimable
# by another worker after this many seconds.
ENGINE_LEASE_SECONDS=30

# Optional: override the worker identity used for lease ownership. Defaults to
# "<hostname>:<pid>:<random>". Set a stable value (e.g. the pod name) if you want
# lease owners to be recognizable in logs.
# ENGINE_WORKER_ID=director-1

# How often Game Director mode polls for runnable games, in milliseconds.
WATCH_POLL_MS=15000

# How often to purge black-box websocket logs older than 48h, in milliseconds.
PURGE_INTERVAL_MS=3600000
