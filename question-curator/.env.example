# Curator engine config. Copy to .env and fill in.
# Uses the SERVICE ROLE key (server-side only) to write drafts and read coverage.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key used to draft questions (same key as the generate-questions edge fn).
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the drafting model (default: claude-sonnet-5).
# ANTHROPIC_MODEL=claude-sonnet-5
